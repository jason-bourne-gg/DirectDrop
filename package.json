{
  "name": "directdrop",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "DirectDrop — send a file straight to another browser over WebRTC. No upload, no server, peer-to-peer.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --port 4173",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["webrtc", "p2p", "file-transfer", "trystero", "serverless"],
  "author": "Aniket Ravindra Charjan",
  "license": "MIT",
  "dependencies": {
    "trystero": "^0.21.5"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
